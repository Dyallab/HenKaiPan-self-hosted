# ── Required ──
DATABASE_URL=postgres://aspm:aspm@postgres:5432/aspm?sslmode=disable
JWT_SECRET=change-this-to-a-random-string
SECRET_ENCRYPTION_KEY=change-this-to-a-64-char-hex-string
ADMIN_USER=admin
# Defaults to admin; subsequent password changes are managed in the UI
# ADMIN_PASS=change-this

# ── Server Configuration ──
# Port to run the API server on (default: 8080)
PORT=8080

# ── Optional: AI Features ──
# At least one provider must be configured for AI features.
# DEFAULT: Ollama (free, self-hosted) for remediation, summary, validation

# Ollama (FREE, self-hosted)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=gemma4:e4b

# OpenRouter (Paid, highest quality)
# OPENROUTER_API_KEY=sk_your_key
# OPENROUTER_MODEL=openai/gpt-4.1-mini

# Cloudflare Workers AI (Paid, cost-effective)
# CF_ACCOUNT_ID=your_account_id
# CF_API_TOKEN=your_api_token
# CF_MODEL=@cf/meta/llama-3.1-8b-instruct

# AI Provider Selection (ollama, openrouter, cloudflare)
# AI_REMEDIATION_PROVIDER=ollama
# AI_SUMMARY_PROVIDER=ollama
# AI_VALIDATION_PROVIDER=ollama

# ── Optional: Email Notifications ──
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# EMAIL_FROM=aspm@example.com

# ── Optional: Integrations ──
# GitHub PR comments (requires GITHUB_TOKEN and GITHUB_PR_NUMBER)
# GITHUB_API_URL=https://api.github.com
# GITHUB_TOKEN=
# GITHUB_PR_NUMBER=

# CORS (for multi-origin setups)
# CORS_ALLOWED_ORIGINS=http://localhost:4321,https://aspm.example.com

# ── Optional: Monitoring ──
# Prometheus metrics endpoint (default: 9090)
# PROMETHEUS_PORT=9090

# ── Optional: License Key (for paid features) ──
# LICENSE_KEY=
# LICENSE_SIGNING_SECRET=
