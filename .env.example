# ── Required ──
# Postgres credentials (used by the postgres container to initialize the database)
POSTGRES_DB=aspm
POSTGRES_USER=aspm
POSTGRES_PASSWORD=aspm
DATABASE_URL=postgres://aspm:aspm@postgres:5432/aspm?sslmode=disable
JWT_SECRET=change-this-to-a-random-string
REDIS_ADDR=redis:6379
SECRET_ENCRYPTION_KEY=change-this-to-a-64-char-hex-string
ADMIN_USER=admin
ADMIN_PASS=admin
PORT=8080

# ── Security: Cookie & CORS ──
# Set COOKIE_SECURE=true when behind HTTPS (REQUIRED for production)
COOKIE_SECURE=false
# COOKIE_DOMAIN=.example.com        # Set when deploying with a real domain (e.g. ".aspm.example.com")
# COOKIE_SAMESITE=lax               # "lax" (default), "strict", or "none" (requires Secure=true)
# CORS_ALLOWED_ORIGINS=https://aspm.example.com  # Comma-separated origins for production

# ── Optional: AI Features ──
# host.docker.internal resolves to the host machine where Ollama runs.
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma4:e4b

# OPENROUTER_API_KEY=sk_your_key
# OPENROUTER_MODEL=openai/gpt-4.1-mini

# CF_ACCOUNT_ID=your_account_id
# CF_API_TOKEN=your_api_token
# CF_MODEL=@cf/meta/llama-3.1-8b-instruct

# AI_REMEDIATION_PROVIDER=ollama
# AI_SUMMARY_PROVIDER=ollama
# AI_VALIDATION_PROVIDER=ollama

# ── Optional: Email Notifications ──
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# EMAIL_FROM=aspm@example.com

# PROMETHEUS_PORT=9090

WEBHOOK_SECRET= # Optional: HMAC signature for webhook validation
LICENSE_KEY= # Paid features
